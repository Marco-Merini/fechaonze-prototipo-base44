{
  "definition": {
    "document": {
      "dsl": "1.0.0",
      "name": "whatsapp_reminder_links",
      "version": "1.0",
      "namespace": "base44"
    },
    "do": [
      {
        "send_links": {
          "call": "invoke_backend_function",
